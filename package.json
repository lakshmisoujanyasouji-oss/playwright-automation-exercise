{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "Production-style Playwright and TypeScript automation framework with UI, API, CI/CD, and AI-assisted testing enhancements",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:api": "playwright test tests/api",
    "report": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "test automation",
    "e2e testing",
    "api testing",
    "ci cd",
    "ai testing"
  ],
  "author": "Lakshmi Soujanya",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0"
  }
}